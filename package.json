{
  "name": "js-web-screen-shot",
  "version": "2.0.2",
  "description": "web端自定义截屏插件(原生JS版)",
  "main": "dist/screenShotPlugin.common.js",
  "private": false,
  "types": "dist/main.d.ts",
  "module": "dist/screenShotPlugin.esm.js",
  "umd:main": "dist/screenShotPlugin.umd.js",
  "publisher": "magicalprogrammer@qq.com",
  "scripts": {
    "build-rollup": "rollup -c --splitCss false --compState false --showPKGInfo true",
    "build-rollup:dev": "rollup -wc --splitCss false --compState false --showPKGInfo true --useDServer true --pkgFormat umd",
    "build-rollup:prod": "rollup -c --splitCss false --compState true && pnpm run fix-dts-path",
    "fix-dts-path": "node scripts/run-with-status.mjs \"fix dts paths\" tsc-alias --outDir ./dist/",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit",
    "test:unit": "jest --runInBand --silent",
    "test:coverage": "jest --runInBand --silent --coverage",
    "test:e2e": "playwright test",
    "test:all": "pnpm run typecheck && pnpm run test:unit && pnpm run test:e2e",
    "verify": "pnpm run test:all && pnpm run build-rollup:prod",
    "release:publish": "sh scripts/release-publish.sh",
    "commit": "git-cz",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/likaia/js-screen-shot.git"
  },
  "keywords": [
    "web-best-screen-shot",
    "web-screen-shot",
    "screen-shot",
    "js-screen-shot",
    "截屏",
    "截图",
    "截图插件",
    "屏幕截图",
    "自定义截图",
    "web端自定义截屏",
    "electron",
    "Electron截图插件"
  ],
  "author": "likaia",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/likaia/js-screen-shot/issues"
  },
  "homepage": "https://www.kaisir.cn/js-screen-shot",
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/preset-env": "^7.20.2",
    "@commitlint/cli": "^11.0.0",
    "@commitlint/config-angular": "^11.0.0",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-alias": "^4.0.3",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^20.0.0",
    "@rollup/plugin-node-resolve": "^13.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-url": "^8.0.1",
    "@types/jest": "^29.5.0",
    "@types/node": "14.14.25",
    "@typescript-eslint/eslint-plugin": "^2.33.0",
    "@typescript-eslint/parser": "^2.33.0",
    "@vue/eslint-config-prettier": "^6.0.0",
    "@vue/eslint-config-typescript": "^5.0.2",
    "autoprefixer": "^10.4.13",
    "cli-progress": "^3.12.0",
    "commitizen": "^4.2.2",
    "core-js": "^3.6.5",
    "cssnano": "^5.1.15",
    "eslint": "^6.7.2",
    "eslint-plugin-decorator-position": "^6.0.0",
    "eslint-plugin-prettier": "^3.1.3",
    "eslint-plugin-vue": "^7.0.0-0",
    "figlet": "^1.11.0",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "ora": "5.4.1",
    "postcss": "^8.4.21",
    "postcss-import": "^15.1.0",
    "postcss-preset-env": "^8.0.1",
    "postcss-url": "^10.1.3",
    "prettier": "^1.19.1",
    "rollup": "^2.59.2",
    "rollup-plugin-copy": "^3.4.0",
    "rollup-plugin-delete": "^2.0.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-serve": "^2.0.2",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.34.1",
    "rollup-plugin-visualizer": "^5.9.0",
    "sass": "1.32.6",
    "sass-loader": "^8.0.2",
    "ts-jest": "^29.0.5",
    "tsc-alias": "^1.8.7",
    "tslib": "^2.6.2",
    "typescript": "~5.0.4",
    "yargs": "^17.7.1"
  },
  "volta": {
    "node": "16.20.2",
    "pnpm": "10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js"
    ]
  },
  "dependencies": {
    "html2canvas": "1.4.1",
    "mobx": "^6.13.5",
    "nanoid": "^4.0.2"
  },
  "files": [
    "/dist"
  ]
}
